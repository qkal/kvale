{
  "name": "kvale",
  "version": "0.1.3",
  "description": "Smart data layer for SvelteKit — fetch, cache, done.",
  "license": "BSD-2-Clause-Patent",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "keywords": [
    "svelte",
    "sveltekit",
    "svelte5",
    "runes",
    "cache",
    "data-fetching",
    "stale-while-revalidate",
    "query",
    "mutation",
    "ssr"
  ],
  "homepage": "https://github.com/qkal/kvale#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qkal/kvale.git"
  },
  "bugs": {
    "url": "https://github.com/qkal/kvale/issues"
  },
  "author": "Kal <czapkovicz@gmail.com> (https://github.com/qkal)",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepublishOnly": "bun test && bun run package",
    "package": "svelte-package -i src",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "peerDependencies": {
    "svelte": "^5.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@sveltejs/package": "^2.3.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/svelte": "^5.2.0",
    "jsdom": "^25.0.0",
    "svelte": "^5.25.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
